APP_NAME="The Bodybuilding Doctor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://thebodybuildingdoctor.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL (Namecheap cPanel)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tbbd
DB_USERNAME=root
DB_PASSWORD=

# For local dev without MySQL, use sqlite:
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# Regenerate Swagger docs on each request in local dev (optional)
L5_SWAGGER_GENERATE_ALWAYS=false

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=mail.your-domain.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,thebodybuildingdoctor.test,app.thrillpharma.de

VITE_APP_NAME="${APP_NAME}"

# Google Play Store URL for the Android app section on the landing page
ANDROID_PLAY_STORE_URL=

# Password for users loaded from database/seeders/data/app-content.json
PASSKEYS_USER_HANDLE_SECRET=

# Face Lock (face-api.js, local models in /public/models)
FACEAUTH_MATCH_THRESHOLD=0.45
FACEAUTH_ENROLLMENT_SAMPLES=3
FACEAUTH_MAX_ATTEMPTS_PER_MINUTE=10
FACEAUTH_REQUIRE_HTTPS=true
FACEAUTH_MODELS_PATH=/models

